# AIDEN 환경변수 예시
# 실제 사용 시 이 파일을 복사하여 .env로 이름을 바꾸고 값을 채우세요.
# .env 는 절대 git 에 커밋하지 마세요.

# --- LLM Provider API Keys ---
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- 런타임 설정 ---
LOG_LEVEL=INFO
DEFAULT_LLM_PROVIDER=gemini

# --- 비용 안전장치 ---
# 한도(USD). 0 이하로 설정하면 해당 검사 비활성.
MONTHLY_BUDGET_USD=15
DAILY_BUDGET_USD=2
PER_RUN_BUDGET_USD=0.50
MAX_LLM_CALLS_PER_RUN=30

# 안전 모드:
#   dry_run     — 실제 LLM 호출 X, 예상 비용만 로그 출력 (개발/디버깅용)
#   development — 정상 호출 + 예산 enforce (기본값)
#   production  — 정상 호출 + 예산 enforce
SAFETY_MODE=development
