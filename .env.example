GOOGLE_AI_STUDIO_API_KEY=your_api_key_here
GEMINI_API_KEY=your_api_key_here  # Settings.gemini_api_key 필드용 (#judge-env-key-mismatch 우회)

# API 서버 (B3-S3-B)
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_LOG_LEVEL=info

# Judge Panel 관련 (선택)
# OpenAI / Anthropic API 키 — Stage 4 Judge Panel 활성 시 필요
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Judge Panel 모델 (선택. 미지정 시 config/agents.yaml 의 judge_panel.models 기본값 사용)
# 우선순위: 어드민 UI 런타임 override > 본 환경변수 > config 기본값
JUDGE_GEMINI_MODEL=
JUDGE_GPT_MODEL=
JUDGE_CLAUDE_MODEL=

# Judge 가중치 override (선택. 미지정 시 config 기본값. 5개 합이 100이어야 함)
JUDGE_WEIGHTS_TOPIC_FIT=
JUDGE_WEIGHTS_CONTENT_QUALITY=
JUDGE_WEIGHTS_INTERACTIVITY=
JUDGE_WEIGHTS_TONE_AUTHENTICITY=
JUDGE_WEIGHTS_TIMELINESS_TRUST=
